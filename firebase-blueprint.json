{
  "entities": {
    "Canvas": {
      "title": "Canvas",
      "description": "A saved digital artwork canvas.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the artwork." },
        "shapes": { "type": "string", "description": "JSON stringified shapes array." },
        "ownerId": { "type": "string", "description": "UID of the owner." },
        "originalId": { "type": "string", "description": "ID of the original canvas if this is a remix." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "shapes", "ownerId", "createdAt", "updatedAt"]
    },
    "MarketplaceItem": {
      "title": "Marketplace Item",
      "description": "An item listed for sale or auction.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "isSold": { "type": "boolean" },
        "ownerId": { "type": "string" },
        "itemType": { "type": "string" },
        "currentBid": { "type": "number" },
        "bidCount": { "type": "number" },
        "endsAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "imageUrl", "ownerId", "itemType"]
    },
    "LiveEvent": {
      "title": "Live Event",
      "description": "A notification event for the feed.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "entityId": { "type": "string" }
      },
      "required": ["type", "message", "timestamp"]
    },
    "LockerItem": {
      "title": "Digital Locker Item",
      "description": "Securely stored neural assets, licenses, or private collections.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string", "description": "The payload (JSON or encrypted string)" },
        "ownerId": { "type": "string" },
        "accessTier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "canvases/{canvasId}": {
      "schema": "Canvas",
      "description": "Stored canvases."
    },
    "marketplace/{itemId}": {
      "schema": "MarketplaceItem",
      "description": "Global marketplace items."
    },
    "live_events/{eventId}": {
      "schema": "LiveEvent",
      "description": "Real-time activity feed."
    },
    "locker/{itemId}": {
      "schema": "LockerItem",
      "description": "Private user and admin storage."
    }
  }
}
