rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'ellanovashenko@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidCanvas(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.shapes is string && data.shapes.size() <= 1000000 &&
             data.ownerId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidMarketplaceItem(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.author is string && data.author.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.ownerId == request.auth.uid &&
             data.itemType in ['sale', 'auction'];
    }

    function isValidLiveEvent(data) {
      return data.type in ['SALE', 'REMIX', 'LIKE', 'MINT'] &&
             data.message is string && data.message.size() <= 256 &&
             data.timestamp == request.time;
    }

    match /canvases/{canvasId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidCanvas(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'shapes', 'updatedAt']) &&
                      request.resource.data.name is string && request.resource.data.name.size() <= 100 &&
                      request.resource.data.shapes is string && request.resource.data.shapes.size() <= 1000000 &&
                      request.resource.data.updatedAt == request.time;
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /marketplace/{itemId} {
      allow read: if true; 
      allow create: if isSignedIn() && isValidMarketplaceItem(request.resource.data);
      allow update: if isSignedIn();
    }

    match /live_events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidLiveEvent(request.resource.data);
    }

    function isValidLockerItem(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.content is string && data.content.size() <= 100000 &&
             data.ownerId == request.auth.uid &&
             data.accessTier in ['private', 'restricted', 'encrypted'] &&
             data.createdAt == request.time;
    }

    match /locker/{itemId} {
      allow get: if isOwner(resource.data.ownerId) || isAdmin();
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidLockerItem(request.resource.data);
      allow update: if (isOwner(resource.data.ownerId) || isAdmin()) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'category', 'content', 'accessTier', 'updatedAt']) &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
  }
}
